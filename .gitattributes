# ============================================================
# Git 属性配置
# ============================================================

# 自动处理文本文件行尾(LF 统一)
* text=auto eol=lf

# Markdown 不去尾随空格(写作友好)
*.md whitespace=-trailing-space

# 脚本类文件
*.sh text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# 二进制
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
